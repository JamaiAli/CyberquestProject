# ─────────────────────────────────────────────────────────────────────────
#  Copie ce fichier en « .env » et remplace les valeurs. Le .env reste local
#  (gitignored) — ne JAMAIS committer de vrais secrets.
# ─────────────────────────────────────────────────────────────────────────

# Secrets JWT — OBLIGATOIRES. Génère chaque valeur avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REMPLACE_MOI_PAR_UNE_VALEUR_ALEATOIRE_48_OCTETS_HEX
JWT_REFRESH_SECRET=REMPLACE_MOI_PAR_UNE_AUTRE_VALEUR_ALEATOIRE

# Fournisseur LLM principal : "gemini" ou "groq". L'autre sert de secours.
LLM_PROVIDER=gemini

# Google Gemini (principal) — jusqu'à 4 clés en rotation auto (quota 429 → suivante)
GEMINI_API_KEY=REMPLACE_MOI
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_MODEL=gemini-2.5-flash

# Groq (secours final)
GROQ_API_KEY=gsk_REMPLACE_MOI
GROQ_MODEL=llama-3.3-70b-versatile
